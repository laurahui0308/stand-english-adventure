<script>

// ============ SOUND SYSTEM ============
const SOUND = {
  ctx: null,
  _init() {
    if (!this.ctx) this.ctx = new (window.AudioContext || window.webkitAudioContext)();
    if (this.ctx && this.ctx.state === 'suspended') this.ctx.resume();
  },
  _play(f, d, t, v) {
    try {
      this._init();
      const o = this.ctx.createOscillator();
      const g = this.ctx.createGain();
      o.type = t || 'square';
      o.frequency.setValueAtTime(f, this.ctx.currentTime);
      g.gain.setValueAtTime(v || 0.15, this.ctx.currentTime);
      g.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + d);
      o.connect(g); g.connect(this.ctx.destination);
      o.start(); o.stop(this.ctx.currentTime + d);
    } catch(e) {}
  },
  _noise(d, v) {
    try {
      this._init();
      const b = this.ctx.createBuffer(1, this.ctx.sampleRate * d, this.ctx.sampleRate);
      const p = b.getChannelData(0);
      for (let i = 0; i < p.length; i++) p[i] = (Math.random() * 2 - 1) * (v || 0.08);
      const s = this.ctx.createBufferSource();
      const g = this.ctx.createGain();
      s.buffer = b;
      g.gain.setValueAtTime(v || 0.08, this.ctx.currentTime);
      g.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + d);
      s.connect(g); g.connect(this.ctx.destination);
      s.start();
    } catch(e) {}
  },
  correct() { this._play(523, 0.1); setTimeout(() => this._play(659, 0.1), 80); setTimeout(() => this._play(784, 0.2), 160); },
  wrong() { this._play(200, 0.3, 'sawtooth', 0.1); },
  click() { this._play(800, 0.04, 'sine', 0.05); },
  bossHit() { this._play(300, 0.15, 'sawtooth', 0.12); },
  bossDefeat() { [523, 659, 784, 1047].forEach((f, i) => setTimeout(() => this._play(f, 0.25), i * 120)); },
  standRush() {
    for (let i = 0; i < 8; i++) {
      setTimeout(() => this._play(200 + Math.random() * 400, 0.08), i * 80);
      setTimeout(() => this._noise(0.05, 0.1), i * 80);
    }
  },
  combo(c) { const b = 400 + Math.min(c, 8) * 50; for (let i = 0; i < Math.min(c, 5); i++) setTimeout(() => this._play(b + i * 60, 0.08), i * 60); },
  evolve() {
    [262, 330, 392, 523, 659, 784, 1047].forEach((f, i) => setTimeout(() => this._play(f, 0.3, 'sine', 0.15), i * 150));
  },
};

