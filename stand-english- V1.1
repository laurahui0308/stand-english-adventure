{npc:"That is so cute! Do you want to see the pandas too?",cn:"See pandas too?",opts:[{t:"Yes please! I heard pandas eat bamboo all day.",s:2,f:"Good knowledge!"},{t:"Yes.",s:1,f:"Say 'yes please'."}]},
{npc:"They do! Let us hurry before it gets too late.",cn:"Let us hurry.",opts:[{t:"Okay! This is the best day ever! Thank you, Mom!",s:2,f:"Sweet!"},{t:"Okay.",s:1,f:"Say thank you."}]}
]},
// === Lv.3 - Seeing a Doctor (NEW) ===
{id:"doctor",n:"Doctor Visit",desc:"Going to the hospital",npc:"Dr. Lee",
scenes:[
{npc:"Hello, what seems to be the problem?",cn:"What is wrong?",opts:[{t:"I have a headache and my throat hurts.",s:2,f:"Clear description!"},{t:"I am sick.",s:1,f:"Describe your symptoms."}]},
{npc:"Let me check your temperature. Open your mouth and say Ah.",cn:"Open your mouth.",opts:[{t:"Ahhh. Is it serious, Doctor?",s:2,f:"Good question!"},{t:"Ahhh.",s:1,f:"Ask 'is it serious'."}]},
{npc:"Do not worry. Just a cold. You need to rest and drink lots of water.",cn:"Just a cold, rest and water.",opts:[{t:"Okay, I will rest. How many days should I stay home?",s:2,f:"Great follow-up!"},{t:"Okay.",s:1,f:"Ask how many days."}]},
{npc:"Two or three days. Here is a note for your teacher. Get well soon!",cn:"Two days rest, here is a note.",opts:[{t:"Thank you, Dr. Lee. I hope I feel better soon.",s:2,f:"Very polite!"},{t:"Thanks.",s:1,f:"Say 'thank you' and 'feel better'."}]}
]},
// === Lv.3 - Birthday Party (NEW) ===
{id:"birthday",n:"Birthday Party",desc:"Attending a friend's party",npc:"Amy",
scenes:[
