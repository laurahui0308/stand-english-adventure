// ============ STAND EVOLUTION TABLE ============
const STAND_TIERS = [
  {lv:0,stars:0,name:'DORMANT',jp:'眠りし者',icon:'💤',color:'rgba(255,255,255,0.3)'},
  {lv:1,stars:50,name:'AWAKENED STAND',jp:'覚醒スタンド',icon:'🔥',color:'var(--pk)'},
  {lv:2,stars:150,name:'SILVER CHARIOT',jp:'シルバーチャリオッツ',icon:'⚔️',color:'var(--tl)'},
  {lv:3,stars:300,name:'GOLDEN EXPERIENCE',jp:'ゴールデンエクスペリエンス',icon:'✨',color:'var(--gd)'},
  {lv:4,stars:500,name:'STAR PLATINUM',jp:'スタープラチナ',icon:'⭐',color:'var(--or)'},
  {lv:5,stars:1000,name:'THE WORLD',jp:'ザ・ワールド',icon:'🌍',color:'var(--rd)'},
];

function getStandLevel(total) {
  let result = STAND_TIERS[0];
  for (let i = STAND_TIERS.length - 1; i >= 0; i--) {
    if (total >= STAND_TIERS[i].stars) { result = STAND_TIERS[i]; break; }
  }
  return result;
}

function getNextTier(currentLv) {
  if (currentLv >= STAND_TIERS.length - 1) return null;
  return STAND_TIERS[currentLv + 1];
}

// ============ STATE ============
var state = {
  stars: parseInt(localStorage.getItem('seS') || '0'),
  totalEarned: parseInt(localStorage.getItem('seT') || '0'),
  combo: 0, maxC: parseInt(localStorage.getItem('seM') || '0'),
  energy: parseInt(localStorage.getItem('seE') || '0'),
  bossDone: JSON.parse(localStorage.getItem('seB') || '[]'),
  curBoss: 0, bossHP: 0, bossLives: 3,
  convDone: JSON.parse(localStorage.getItem('seCD') || '[]'),
  convIdx: 0, convSc: 0, convSt: 0, convLock: false,
  ri: 0, rs: 0, ra: {},
  dailyDate: localStorage.getItem('seDD') || '',
  dailyStreak: parseInt(localStorage.getItem('seDS') || '0'),
  dailyDone: localStorage.getItem('seDDone') || '',
  dailyIdx: 0, dailyStars: 0,
  lastStandLv: parseInt(localStorage.getItem('seSL') || '0'),
};

function save() {
  localStorage.setItem('seS', state.stars);
  localStorage.setItem('seT', state.totalEarned);
  localStorage.setItem('seE', state.energy);
  localStorage.setItem('seM', Math.max(state.maxC, state.combo));
  localStorage.setItem('seB', JSON.stringify(state.bossDone));
  localStorage.setItem('seCD', JSON.stringify(state.convDone));
  localStorage.setItem('seDD', state.dailyDate);
  localStorage.setItem('seDS', state.dailyStreak);
  localStorage.setItem('seDDone', state.dailyDone);
  localStorage.setItem('seSL', getStandLevel(state.totalEarned).lv);
}

function today() {
  return new Date().toISOString().slice(0, 10);
}

function addStars(n) {
  state.stars += n;
  state.totalEarned += n;
  state.energy += n;
  var prevLv = getStandLevel(state.totalEarned - n).lv;
  var newLv = getStandLevel(state.totalEarned).lv;
  if (state.energy >= 100) { state.energy = 0; sRush(); }
  if (newLv > prevLv) {
    setTimeout(function() { triggerEvolution(newLv); }, 600);
  }
  ui(); save();
}

function ui() {
  var sc = document.getElementById('stC');
  if (sc) sc.textContent = state.stars;
  var sb = document.getElementById('sBar');
  if (sb) sb.style.width = Math.min(state.energy, 100) + '%';
  var sp = document.getElementById('sp');
  if (sp) sp.textContent = Math.min(state.energy, 100) + '%';
  updateStandDisplay();
  updateDailyDisplay();
  var st = document.getElementById('seTotal');
  if (st) st.textContent = 'Total: ' + state.totalEarned;
}

// ============ STAND EVOLUTION UI ============
function updateStandDisplay() {
  var total = state.totalEarned;
  var cur = getStandLevel(total);
  var next = getNextTier(cur.lv);

  var icon = document.getElementById('seIcon');
  var name = document.getElementById('seName');
  var lv = document.getElementById('seLv');
  var fill = document.getElementById('seFill');
  var prog = document.getElementById('seProg');

  if (icon) icon.textContent = cur.icon;
  if (name) name.textContent = cur.name;
  if (lv) lv.textContent = 'Lv.' + cur.lv + ' — ' + cur.jp;

  if (next) {
    var progress = Math.min(100, Math.floor(((total - cur.stars) / (next.stars - cur.stars)) * 100));
    if (fill) fill.style.width = progress + '%';
    if (prog) prog.textContent = (total - cur.stars) + '/' + (next.stars - cur.stars);
  } else {
    if (fill) fill.style.width = '100%';
    if (prog) prog.textContent = 'MAX';
  }
}

function showEvolution() {
  SOUND.click();
  sm('e');
  var total = state.totalEarned;
  var cur = getStandLevel(total);
  var h = '<div class="evo-page">';

  // Current Stand
  h += '<div class="evo-current">';
  h += '<div class="evo-big-icon">' + cur.icon + '</div>';
  h += '<div class="evo-big-name">' + cur.name + '</div>';
  h += '<div class="evo-big-jp">' + cur.jp + '</div>';
  h += '<div class="evo-big-lv">Lv.' + cur.lv + (cur.lv >= 5 ? ' — THE STRONGEST' : '') + '</div>';
  h += '</div>';

  // Progress to next
  var next = getNextTier(cur.lv);
  if (next) {
    var need = next.stars - total;
    h += '<div style="font-size:13px;color:rgba(255,255,255,0.5);margin-bottom:12px">' + need + ' more stars to ' + next.name + '</div>';
  } else {
    h += '<div style="font-size:13px;color:var(--gd);margin-bottom:12px">★ ALL MASTERY ACHIEVED ★</div>';
  }

  // All tiers
  h += '<div class="evo-list">';
  for (var i = 0; i < STAND_TIERS.length; i++) {
    var t = STAND_TIERS[i];
    var unlocked = total >= t.stars;
    var cls = unlocked ? '' : ' locked';
    if (t.lv === cur.lv) cls += ' current';
    h += '<div class="evo-item' + cls + '">';
    h += '<div class="evo-item-icon">' + (unlocked ? t.icon : '🔒') + '</div>';
    h += '<div class="evo-item-info">';
    h += '<div class="evo-item-name">' + t.name + '</div>';
    h += '<div class="evo-item-jp">' + t.jp + '</div>';
    h += '</div>';
    h += '<div class="evo-item-stars">' + t.stars + '⭐</div>';
    h += '</div>';
  }
  h += '</div></div>';

  document.getElementById("eC").innerHTML = h;
}

function triggerEvolution(lv) {
  var t = STAND_TIERS[lv];
  SOUND.evolve();
  state.lastStandLv = lv;
  save();

  var overlay = document.createElement('div');
  overlay.className = 'evo-overlay';
  overlay.innerHTML =
    '<div class="evo-title">Stand Evolution</div>' +
    '<div class="evo-icon">' + t.icon + '</div>' +
    '<div class="evo-name">' + t.name + '</div>' +
    '<div class="evo-jp">' + t.jp + '</div>' +
    '<div class="evo-desc">Your Stand has evolved to Lv.' + lv + '!</div>' +
    '<button class="evo-btn" onclick="this.parentElement.remove()">AWAKEN</button>';
  document.body.appendChild(overlay);
}

// ============ MODULE SWITCH ============
function sm(name) {
  SOUND._init();
  var mods = document.querySelectorAll('.md');
  for (var i = 0; i < mods.length; i++) mods[i].classList.remove('a');
  if (name === 'm') {
    document.getElementById('menu').classList.add('a'); ui();
    checkDailyReset();
  }
  else if (name === 'w') { document.getElementById('wM').classList.add('a'); bossSelect(); }
  else if (name === 'r') { document.getElementById('rM').classList.add('a'); startRead(); }
  else if (name === 's') { document.getElementById('sM').classList.add('a'); startConv(); }
  else if (name === 'e') { document.getElementById('eM').classList.add('a'); showEvolution(); }
  else if (name === 'd') { document.getElementById('dM').classList.add('a'); renderDaily(); }
}

// ============ STAND RUSH ============
function sRush() {
  var d = document.createElement('div');
  d.className = 'sro';
  d.innerHTML = '<div style="font-size:36px;font-weight:900;background:linear-gradient(135deg,var(--gd),var(--pk),var(--tl));-webkit-background-clip:text;-webkit-text-fill-color:transparent">STAND RUSH!</div><div style="font-size:24px;margin:12px">ORAAAAA!</div><div style="font-size:20px;color:var(--gd)">+10 Stars!</div><button class="bo" onclick="this.parentElement.remove()">Continue</button>';
  document.body.appendChild(d);
  addStars(10);
  SOUND.standRush();
}

function ora() {
  var e = document.createElement('div');
  e.className = 'or';
  e.style.left = (20 + Math.random() * 60) + '%';
  e.style.top = (20 + Math.random() * 60) + '%';
  e.innerHTML = '<div style="font-size:48px;font-weight:900;color:var(--gd)">ORA!</div>';
  document.body.appendChild(e);
  setTimeout(function() { e.remove(); }, 800);
}

function menacing() {
  var e = document.createElement('div');
  e.className = 'menacing';
  e.style.left = (10 + Math.random() * 40) + '%';
  e.style.top = (10 + Math.random() * 40) + '%';
  e.innerHTML = 'ゴゴゴゴ';
  document.body.appendChild(e);
  setTimeout(function() { e.remove(); }, 2000);
}

