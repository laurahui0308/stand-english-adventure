// ============ BOSS BATTLE ============
function bossSelect() {
  state.combo = 0; state.curBoss = 0;
  var B = [
    {id:"animals",n:"[Beast King]",e:"AN",tp:"animals",hp:5},
    {id:"food",n:"[Food Demon]",e:"FD",tp:"food",hp:5},
    {id:"school",n:"[Principal Fiend]",e:"PF",tp:"school",hp:5},
    {id:"nature",n:"[Nature Giant]",e:"NG",tp:"nature",hp:5},
    {id:"daily",n:"[Daily Assassin]",e:"DA",tp:"daily",hp:5},
    {id:"emotions",n:"[Emotion Mage]",e:"EM",tp:"emotions",hp:5},
    {id:"final",n:"[Dark Overlord]",e:"DO",tp:"final",hp:10,f:true}
  ];
  var fu = B.slice(0,6).every(function(b) { return state.bossDone.indexOf(b.id) >= 0; });
  var allDone = fu && state.bossDone.indexOf("final") >= 0;
  var h = '<div class="mg">';
  for (var i = 0; i < B.length; i++) {
    var b = B[i];
    var cl = state.bossDone.indexOf(b.id) >= 0;
    var ul = i === 0 || state.bossDone.indexOf(B[i-1].id) >= 0 || (b.f && fu);
    h += '<div class="bc' + (cl ? '' : '') + '" onclick="' + (ul ? 'startBoss(' + i + ')' : '') + '"><div class="be">' + b.e + '</div><div class="bi"><h3>' + b.n + '</h3><p>' + (b.f ? 'All words!' : b.tp) + '</p></div><div class="bb ' + (cl ? 'c' : (ul ? 'g' : 'l')) + '\">' + (cl ? 'CLEAR' : (ul ? 'FIGHT' : 'LOCKED')) + '</div></div>';
  }
  h += '</div>';
  h += '<div style="display:flex;gap:8px;margin-top:8px">';
  h += '<div class="mb" onclick="endlessMode()" style="flex:1;justify-content:center;border-color:var(--tl);padding:14px"><span>♾️ INFINITE</span><span style="font-size:11px;color:rgba(255,255,255,0.4);margin-left:6px">Unlimited Practice</span></div>';
  h += '<div class="mb" onclick="resetBoss()" style="flex:0;padding:14px;border-color:rgba(255,255,255,0.15)">🔄 RESET</div>';
  h += '</div>';
  if (allDone) {
    h += '<div style="margin-top:10px;padding:12px;border-radius:12px;background:rgba(255,215,0,0.1);border:1px solid var(--gd);font-size:13px">🏆 ALL BOSSES DEFEATED! You are truly the Stand Master!</div>';
  }
  document.getElementById("wC").innerHTML = h;
}

const BOSSES = [
{id:"animals",n:"[Beast King]",tp:"animals",hp:5},
{id:"food",n:"[Food Demon]",tp:"food",hp:5},
{id:"school",n:"[Principal Fiend]",tp:"school",hp:5},
{id:"nature",n:"[Nature Giant]",tp:"nature",hp:5},
{id:"daily",n:"[Daily Assassin]",tp:"daily",hp:5},
{id:"emotions",n:"[Emotion Mage]",tp:"emotions",hp:5},
{id:"final",n:"[Dark Overlord]",tp:"final",hp:10,f:true}
];

var bossLock = false;
var endlessLock = false;

function startBoss(idx) {
  var b = BOSSES[idx];
  state.curBoss = idx;
  state.bossLives = 3;
  state.bossHP = b.hp;
  state.combo = 0;
  bossLock = false;
  bossRender();
}

function bossRender() {
  document.getElementById("wC").innerHTML = "<div style='padding:20px'>...</div>";
  var b = BOSSES[state.curBoss];
  bossLock = false;
  var word;
  if (b.f) {
    var av = WORDS.filter(function(w) { return state.bossDone.indexOf(w.tp) < 0; });
    if (av.length === 0) { bossWin(); return; }
    word = av[Math.floor(Math.random() * av.length)];
  } else {
    var pool = WORDS.filter(function(w) { return w.tp === b.tp; });
    word = pool[Math.floor(Math.random() * pool.length)];
  }
  var pool2 = WORDS.filter(function(w) { return w.en !== word.en; });
  pool2.sort(function() { return 0.5 - Math.random(); });
  var dists = pool2.slice(0, 3);
  var opts, correct, display;
  var qtype = Math.random() > 0.5 ? "en2zh" : "zh2en";
  if (qtype === "en2zh") {
    display = word.en + "  (" + word.ph + ")";
    opts = [word.zh, dists[0].zh, dists[1].zh, dists[2].zh];
  } else {
    display = word.zh;
    opts = [word.en, dists[0].en, dists[1].en, dists[2].en];
  }
  opts.sort(function() { return 0.5 - Math.random(); });
  correct = opts.indexOf(qtype === "en2zh" ? word.zh : word.en);

  var h = '<div class="back" onclick="bossSelect()">◀ Back</div>';
  h += '<div class="bh"><div><div class="bnm">' + b.n + '</div></div>';
  h += '<div style="flex:1"><div class="bho"><div class="bhi" id="bhp" style="width:' + ((state.bossHP / b.hp) * 100) + '%"></div></div>';
  h += '<div class="bht">HP: ' + state.bossHP + '/' + b.hp + '</div></div>';
  h += '<div class="pl" id="lives">';
  for (var li = 0; li < 3; li++) h += '<span class="' + (li >= state.bossLives ? 'ht-l' : '') + '">❤️</span>';
  h += '</div></div>';
  h += '<div class="pr">' + state.combo + ' COMBO</div>';
  h += '<div class="wc"><div class="wd">' + display + '</div></div>';
  h += '<div class="og" id="bOpts">';
  for (var oi = 0; oi < opts.length; oi++) {
    h += '<button class="ob" onclick="checkBoss(this,' + oi + ',' + correct + ')">' + opts[oi] + '</button>';
  }
  h += '</div><div class="cd" id="cdEndless"></div>';
  document.getElementById("wC").innerHTML = h;
}

function checkBoss(el, idx, correct) {
  if (bossLock) return;
  bossLock = true;
  var btns = document.querySelectorAll("#bOpts .ob");
  for (var i = 0; i < btns.length; i++) btns[i].disabled = true;
  if (idx === correct) {
    el.classList.add("cr");
    state.bossHP--; state.combo++;
    SOUND.correct();
    if (state.combo >= 3) { SOUND.combo(state.combo); ora(); }
    var b = BOSSES[state.curBoss];
    var f = document.getElementById("bhp");
    if (f) f.style.width = ((state.bossHP / b.hp) * 100) + "%";
    var bonus = state.combo >= 3 ? Math.floor(state.combo / 3) : 0;
    addStars(1 + bonus);
    document.getElementById("cdBoss").innerHTML = "<span style='color:var(--tl)'>HIT! +" + (1+bonus) + " stars</span>";
    if (state.bossHP <= 0) { setTimeout(bossWin, 600); }
    else { setTimeout(function() { bossLock = false; bossRender(); }, 800); }
  } else {
    el.classList.add("wr");
    btns[correct].classList.add("cr");
    state.bossLives--; state.combo = 0;
    SOUND.wrong();
    document.getElementById("cdBoss").innerHTML = "<span style='color:var(--rd)'>BOSS attacks! Lost a life</span>";
    var l = document.getElementById("lives");
    if (l) {
      var lh = "";
      for (var i = 0; i < 3; i++) lh += "<span class='" + (i >= state.bossLives ? "ht-l" : "") + "'>❤️</span>";
      l.innerHTML = lh;
    }
    if (state.bossLives <= 0) { setTimeout(bossLose, 800); }
    else { setTimeout(function() { bossLock = false; bossRender(); }, 1200); }
  }
}

function bossWin() {
  var b = BOSSES[state.curBoss];
  if (state.bossDone.indexOf(b.id) === -1) { state.bossDone.push(b.id); save(); }
  SOUND.bossDefeat();
  addStars(b.f ? 35 : 5);
  document.getElementById("wC").innerHTML = "<div class='rc'><div style='font-size:36px;font-weight:900;color:var(--gd)'>VICTORY!</div><div style='color:rgba(255,255,255,0.6);margin:6px 0'>" + b.n + " defeated!</div><div style='margin-top:12px'><button class='sk' onclick='bossSelect()'>Continue</button></div></div>";
  if (b.f) {
    var d = document.createElement("div");
    d.className = "sro";
    d.innerHTML = "<div style='font-size:32px;font-weight:900'>ALL CLEAR!</div><div style='font-size:24px;margin:12px;color:var(--gd)'>+35 Bonus Stars!</div><button class='bo' onclick='this.parentElement.remove()'>OK</button>";
    document.body.appendChild(d);
  }
}

function bossLose() {
  document.getElementById("wC").innerHTML = "<div class='rc'><div style='font-size:48px'>💀</div><div style='font-size:18px;font-weight:700;margin:8px 0'>You were defeated!</div><div style='color:rgba(255,255,255,0.5);margin-bottom:12px'>But a Stand never gives up!</div><button class='sk' onclick='startBoss(" + state.curBoss + ")'>Retry</button><button class='sk' onclick='bossSelect()' style='margin-left:8px'>Back</button></div>";
}

function resetBoss() {
  if (confirm("Reset all bosses?")) {
    state.bossDone = []; save(); bossSelect();
  }
}

// ============ ENDLESS MODE ============
function endlessMode() {
  state.combo = 0; endlessLock = false; endlessQ();
}

function endlessQ() {
  endlessLock = false;
  var qtype = Math.random() > 0.5 ? "en2zh" : "zh2en";
  var word = WORDS[Math.floor(Math.random() * WORDS.length)];
  var pool = WORDS.filter(function(w) { return w.en !== word.en; });
  pool.sort(function() { return 0.5 - Math.random(); });
  var dists = pool.slice(0, 3);
  var opts, correct, display;
  if (qtype === "en2zh") {
    display = word.en + "  (" + word.ph + ")";
    opts = [word.zh, dists[0].zh, dists[1].zh, dists[2].zh];
  } else {
    display = word.zh;
    opts = [word.en, dists[0].en, dists[1].en, dists[2].en];
  }
  opts.sort(function() { return 0.5 - Math.random(); });
  correct = opts.indexOf(qtype === "en2zh" ? word.zh : word.en);
  var h = '<div class="back" onclick="bossSelect()">◀ Back</div>';
  h += '<div class="pr">♾️ INFINITE • ' + state.combo + ' COMBO • ⭐ ' + state.stars + '</div>';
  h += '<div class="wc"><div class="wd">' + display + '</div></div>';
  h += '<div class="og" id="eOpts">';
  for (var oi = 0; oi < opts.length; oi++) {
    h += '<button class="ob" onclick="checkEndless(this,' + oi + ',' + correct + ')">' + opts[oi] + '</button>';
  }
  h += '</div><div class="cd" id="cdEndless"></div>';
  document.getElementById("wC").innerHTML = h;
}

function checkEndless(el, idx, correct) {
  if (endlessLock) return;
  endlessLock = true;
  var btns = document.querySelectorAll("#eOpts .ob");
  for (var i = 0; i < btns.length; i++) btns[i].disabled = true;
  if (idx === correct) {
    el.classList.add("cr"); state.combo++;
    SOUND.correct();
    if (state.combo >= 3) { SOUND.combo(state.combo); ora(); menacing(); }
    var bonus = state.combo >= 3 ? Math.floor(state.combo / 3) : 0;
    addStars(1 + bonus);
    document.getElementById("cdEndless").innerHTML = "<span style='color:var(--tl)">Correct! +" + (1+bonus) + " stars</span>";
    setTimeout(function() { endlessQ(); }, 600);
  } else {
    el.classList.add("wr");
    btns[correct].classList.add("cr");
    state.combo = 0;
    SOUND.wrong();
    document.getElementById("cdEndless").innerHTML = "<span style='color:var(--rd)">Not quite!</span>";
    setTimeout(function() { endlessQ(); }, 1200);
  }
}

// ============ READING ============
function startRead() {
  state.ri = 0; state.rs = 0; state.ra = {};
  showRead();
}

function showRead() {
  if (state.ri >= READINGS.length) {
    var bonus = Math.floor(state.rs / 3);
    if (bonus > 0) addStars(bonus);
    document.getElementById("rC").innerHTML = "<div class='rc'><div style='font-size:36px;font-weight:900;color:var(--gd)'>ALL CLEAR!</div><div style='color:rgba(255,255,255,0.5);margin:6px 0'>Reading Trial complete</div><div style='color:var(--tl)'>+ " + bonus + " stars</div></div>";
    return;
  }
  var r = READINGS[state.ri];
  state.ra = {};
  var h = '<div class="pr">📖 Story ' + (state.ri + 1) + '/' + READINGS.length + '</div>';
  h += '<div class="rb"><div style="font-weight:700;color:var(--gd);margin-bottom:8px">' + r.title + '</div><div>' + r.text + '</div>';
  h += '<div class="trans-btn" onclick="var t=this.nextElementSibling;t.style.display=t.style.display===\'block\'?\'none\':\'block\'">🌐 Translation</div>';
  h += '<div class="translation">' + r.translation + '</div></div>';
  r.questions.forEach(function(q, qi) {
    h += '<div class="qi" id="rq' + qi + '"><div class="question-text">' + (qi + 1) + ". " + q.q + '</div>';
    q.options.forEach(function(o, oi) {
      h += '<button class="qo" onclick="checkRead(this,' + qi + ',' + oi + ',' + q.answer + ')">' + o + '</button>';
    });
    h += '</div>';
  });
  document.getElementById("rC").innerHTML = h;
}

function checkRead(el, qi, oi, ai) {
  if (state.ra[qi]) return;
  state.ra[qi] = true;
  var btns = document.querySelectorAll("#rq" + qi + " .qo");
  for (var i = 0; i < btns.length; i++) btns[i].disabled = true;
  if (oi === ai) {
    el.classList.add("cr");
    state.rs++;
    SOUND.correct();
  } else {
    el.classList.add("wr");
    btns[ai].classList.add("cr");
    SOUND.wrong();
  }
  if (Object.keys(state.ra).length >= READINGS[state.ri].questions.length) {
    setTimeout(function() { state.ri++; showRead(); }, 1500);
  }
}

