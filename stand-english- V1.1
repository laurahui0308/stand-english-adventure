];

function startConv() {
  state.convIdx = 0; state.convSc = 0; state.convSt = 0; state.convLock = false;
  convList();
}

function convList() {
  var h = '<div class="mg">';
  CONVS.forEach(function(c, i) {
    var done = state.convDone.indexOf(c.id) >= 0;
    h += '<div class="bc" onclick="startConvOne(' + i + ')"><div class="be">💬</div><div class="bi"><h3>' + c.n + '</h3><p>' + c.desc + '</p></div><div class="bb ' + (done ? 'c' : 'g') + '\">' + (done ? 'DONE' : 'START') + '</div></div>';
  });
  h += '</div>';
  document.getElementById("sC").innerHTML = h;
}

function startConvOne(idx) {
  state.convIdx = idx; state.convSc = 0; state.convSt = 0; state.convLock = false;
  convScene();
}

function convScene() {
  var c = CONVS[state.convIdx];
  if (state.convSc >= c.scenes.length) {
    var isNew = state.convDone.indexOf(c.id) < 0;
    if (isNew) {
      state.convDone.push(c.id);
      state.convSt = Math.min(state.convSt, 8);
      var bonus = Math.floor(state.convSt / 4);
      if (bonus > 0) addStars(bonus);
    }
    save();
    var displayed = isNew ? (Math.floor(Math.min(state.convSt, 8) / 4)) : 0;
    document.getElementById("sC").innerHTML = "<div class='rc'><div style='font-size:36px;font-weight:900;color:var(--gd)'>FRIEND MADE!</div><div style='color:var(--tl)'>+ " + displayed + " stars</div><div style='color:rgba(255,255,255,0.5);margin:6px 0'>" + c.n + (isNew ? " completed!" : " (replay)") + "</div><div style='margin-top:12px'><button class='sk' onclick='startConvOne(" + state.convIdx + ")'>Again</button><button class='sk' onclick='convList()' style='margin-left:8px'>Back</button></div></div>";
    return;
  }
  var sc = c.scenes[state.convSc];
  var h = '<div class="cb"><div class="cbp"><div class="cbn">👤 [' + c.npc + ']</div><div class="cbb">' + sc.npc + '<div style="font-size:12px;color:rgba(255,255,255,0.4);margin-top:4px">' + sc.cn + '</div></div></div>';
  h += '<div id="cOpts">';
  var letters = ["A","B"];
  sc.opts.forEach(function(o, oi) {
    h += '<div class="cho" id="co' + oi + '" onclick="pickResp(' + oi + ')"><span class="cho-l" style="width:24px;height:24px;border-radius:50%;background:rgba(255,255,255,0.1);display:inline-flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0">' + letters[oi] + '</span><span>' + o.t + '</span></div>';
  });
  h += '</div><div class="cf" id="cf"></div></div>';
  document.getElementById("sC").innerHTML = h;
  // TTS
  setTimeout(function() {
    if (window.speechSynthesis) {
      var u = new SpeechSynthesisUtterance(sc.npc);
      u.lang = "en-US"; u.rate = 0.8;
      speechSynthesis.cancel();
      speechSynthesis.speak(u);
    }
  }, 300);
}

function pickResp(oi) {
  if (state.convLock) return;
  state.convLock = true;
  var c = CONVS[state.convIdx];
  var sc = c.scenes[state.convSc];
  var o = sc.opts[oi];
  state.convSt += o.s;
  SOUND.correct();
  document.getElementById("cf").innerHTML = "💬 " + o.f;
  var btns = document.querySelectorAll("#cOpts .cho");
  for (var i = 0; i < btns.length; i++) { btns[i].style.pointerEvents = "none"; btns[i].style.opacity = "0.6"; }
  var sel = document.getElementById("co" + oi);
  if (sel) sel.className = "cho s";
  setTimeout(function() {
    state.convSc++;
    state.convLock = false;
    convScene();
  }, 1500);
}

// ============ DAILY CHALLENGE ============
function checkDailyReset() {
  var todayStr = today();
  if (state.dailyDate !== todayStr) {
    if (state.dailyDate !== '') {
      var lastDate = new Date(state.dailyDate);
      var now = new Date(todayStr);
      var diffDays = Math.floor((now - lastDate) / (1000 * 60 * 60 * 24));
      if (diffDays > 1) {
        state.dailyStreak = 0;
      }
    }
    state.dailyDone = '';
    state.dailyIdx = 0;
    state.dailyStars = 0;
    save();
  }
}

function updateDailyDisplay() {
  var todayStr = today();
  var done = state.dailyDone === todayStr;
  var card = document.getElementById('dcCard');
  var badge = document.getElementById('dcBadge');
  var streak = document.getElementById('dcStreak');

  if (streak) streak.textContent = '🔥 ' + state.dailyStreak + ' days streak';

  if (badge) {
    if (done) {
      badge.textContent = '✅ DONE';
      badge.style.background = 'var(--tl)';
    } else {
      badge.textContent = 'START';
      badge.style.background = 'var(--gd)';
    }
  }

  if (card) {
    card.style.borderColor = done ? 'var(--tl)' : 'rgba(255,215,0,0.25)';
  }
}

function startDaily() {
  checkDailyReset();
  SOUND.click();
  var todayStr = today();
  if (state.dailyDone === todayStr) {
    // Already done today, show summary
    sm('d');
    renderDailyDone();
    return;
  }
  sm('d');
  state.dailyIdx = 0;
  state.dailyStars = 0;
  renderDailyQ();
}

function renderDaily() {
  var todayStr = today();
  if (state.dailyDone === todayStr) {
    renderDailyDone();
  } else {
    state.dailyIdx = 0;
    state.dailyStars = 0;
    state.dailyAnswers = [];
    renderDailyQ();
  }
}

function renderDailyQ() {
  if (state.dailyIdx >= 5) {
    // Daily done!
    var todayStr = today();
    state.dailyDone = todayStr;
    state.dailyDate = todayStr;
    state.dailyStreak++;
    save();
    ui();
    renderDailyDone();
    return;
  }

  // Pick random question
  var word = WORDS[Math.floor(Math.random() * WORDS.length)];
  var qtype = Math.random() > 0.5 ? "en2zh" : "zh2en";
  var pool = WORDS.filter(function(w) { return w.en !== word.en; });
  pool.sort(function() { return 0.5 - Math.random(); });
  var dists = pool.slice(0, 3);
  var opts, correct, display;
  if (qtype === "en2zh") {
    display = word.en + "  (" + word.ph + ")";
    opts = [word.zh, dists[0].zh, dists[1].zh, dists[2].zh];
  } else {
    display = word.zh;
    opts = [word.en, dists[0].en, dists[1].en, dists[2].en];
  }
  opts.sort(function() { return 0.5 - Math.random(); });
  correct = opts.indexOf(qtype === "en2zh" ? word.zh : word.en);

  var h = '<div class="back" onclick="sm(\'m\')">◀ Back</div>';

  // Streak bar
  h += '<div class="dq-streak-bar">';
  var maxDots = Math.min(state.dailyStreak, 14);
  var fireLevel = 0;
  if (state.dailyStreak >= 14) fireLevel = 4;
  else if (state.dailyStreak >= 7) fireLevel = 3;
  else if (state.dailyStreak >= 3) fireLevel = 2;
  else if (state.dailyStreak >= 1) fireLevel = 1;

  for (var s = 0; s < Math.max(5, maxDots); s++) {
    var cls = 'dq-streak-dot';
    if (s < state.dailyStreak) cls += ' active';
    if (s >= state.dailyStreak - 1 && s < state.dailyStreak && state.dailyStreak > 0) cls += ' fire';
    h += '<span class="' + cls + '">🔥</span>';
  }
  h += '</div>';

  h += '<div class="dq-blueprint">';
  h += '<div class="dq-header">';
  h += '<div class="dq-day">📅 DAILY CHALLENGE</div>';
  h += '<div class="dq-progress">' + (state.dailyIdx + 1) + '/5</div>';
  h += '</div>';

  h += '<div class="wc" style="margin-bottom:12px"><div class="wd" style="font-size:28px">' + display + '</div></div>';

  h += '<div class="og" id="dOpts">';
  for (var oi = 0; oi < opts.length; oi++) {
    h += '<button class="ob" onclick="checkDaily(this,' + oi + ',' + correct + ')">' + opts[oi] + '</button>';
  }
  h += '</div><div class="cd" id="cdEndless"></div>';

  // Rewards info
  var bonusStr = '';
  if (state.dailyStreak >= 14) bonusStr = '🔥 x4 Bonus!';
  else if (state.dailyStreak >= 7) bonusStr = '🔥 x3 Bonus!';
  else if (state.dailyStreak >= 3) bonusStr = '🔥 x2 Bonus!';
  else bonusStr = '🔥 x1';

  h += '<div style="font-size:11px;color:rgba(255,255,255,0.3);margin-top:10px;text-align:center">' + bonusStr + ' • Streak: ' + state.dailyStreak + ' days</div>';

  h += '</div>';
  document.getElementById("dC").innerHTML = h;
}

var dailyLock = false;

function checkDaily(el, idx, correct) {
  if (dailyLock) return;
  dailyLock = true;
  var btns = document.querySelectorAll("#dOpts .ob");
  for (var i = 0; i < btns.length; i++) btns[i].disabled = true;
  if (idx === correct) {
    el.classList.add("cr");
    SOUND.correct();
    state.dailyStars++;
    document.getElementById("cdDaily").innerHTML = "<span style='color:var(--tl)'>HIT!</span>";
  } else {
    el.classList.add("wr");
    btns[correct].classList.add("cr");
    SOUND.wrong();
    document.getElementById("cdDaily").innerHTML = "<span style='color:var(--rd)'>MISS!</span>";
  }
  setTimeout(function() {
    state.dailyIdx++;
    dailyLock = false;
    renderDailyQ();
  }, 800);
}

function renderDailyDone() {
  var multiplier = 1;
  if (state.dailyStreak >= 14) multiplier = 4;
  else if (state.dailyStreak >= 7) multiplier = 3;
  else if (state.dailyStreak >= 3) multiplier = 2;

  var earned = state.dailyStars * multiplier;
  var h = '<div class="back" onclick="sm(\'m\')">◀ Back</div>';

  // Streak bar
  h += '<div class="dq-streak-bar">';
  var maxDots2 = Math.min(state.dailyStreak, 14);
  for (var s2 = 0; s2 < Math.max(5, maxDots2); s2++) {
    var cls2 = 'dq-streak-dot';
    if (s2 < state.dailyStreak) cls2 += ' active';
    if (s2 >= state.dailyStreak - 1 && s2 < state.dailyStreak && state.dailyStreak > 0) cls2 += ' fire';
    h += '<span class="' + cls2 + '">🔥</span>';
  }
  h += '</div>';

  h += '<div class="rc">';
  h += '<div style="font-size:48px;margin-bottom:8px">📅</div>';
  h += '<div style="font-size:24px;font-weight:900;color:var(--gd)">DAILY COMPLETE!</div>';
  h += '<div style="font-size:14px;color:rgba(255,255,255,0.5);margin:8px 0">Correct: ' + state.dailyStars + '/5</div>';
  h += '<div style="font-size:20px;color:var(--tl)">+ ' + earned + ' Stars</div>';

  if (multiplier > 1) {
    h += '<div style="font-size:13px;color:var(--or);margin-top:4px">🔥 x' + multiplier + ' Streak Bonus!</div>';
  }

  h += '<div style="margin-top:12px;padding:8px;border-radius:10px;background:rgba(255,255,255,0.05)">';
  h += '<div style="font-size:12px;color:rgba(255,255,255,0.4)">🔥 ' + state.dailyStreak + ' day streak</div>';
  if (state.dailyStreak >= 14) h += '<div style="font-size:11px;color:var(--or)">★ MAX MULTIPLIER ACHIEVED!</div>';
  else if (state.dailyStreak >= 7) h += '<div style="font-size:11px;color:var(--gd)">★ 7 days - x3 active!</div>';
  else if (state.dailyStreak >= 3) h += '<div style="font-size:11px;color:var(--tl)">★ 3 days - x2 active!</div>';

  // Next milestone
  var nextMs = '';
  if (state.dailyStreak < 3) nextMs = 3 - state.dailyStreak + ' days to x2';
  else if (state.dailyStreak < 7) nextMs = 7 - state.dailyStreak + ' days to x3';
  else if (state.dailyStreak < 14) nextMs = 14 - state.dailyStreak + ' days to MAX';
  h += '<div style="font-size:11px;color:rgba(255,255,255,0.3);margin-top:4px">Next: ' + nextMs + '</div>';
  h += '</div>';

  h += '</div>';

  document.getElementById("dC").innerHTML = h;

  // Award stars (only if not already awarded today)
  var todayStr = today();
  var awarded = localStorage.getItem('seDA_' + todayStr);
  if (!awarded && earned > 0) {
    addStars(earned);
    localStorage.setItem('seDA_' + todayStr, '1');
    save();
  }
}

// ============ INIT ============
checkDailyReset();
ui();

// ============ PWA Service Worker Registration ============
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('./service-worker.js').then(function(reg) {
    console.log('[PWA] Service Worker registered:', reg.scope);
  }).catch(function(err) {
    console.log('[PWA] Service Worker registration failed:', err);
  });
}
</script>
</body>
</html>
