{npc:"Oh, you did not have to! Can I open it now?",cn:"Can I open it?",opts:[{t:"Of course! I hope you like it.",s:2,f:"Very kind!"},{t:"Yes.",s:1,f:"Say 'of course'."}]},
{npc:"Wow! A beautiful notebook! I love it! Thank you so much!",cn:"She loves it!",opts:[{t:"I am so happy you like it! I know you love writing.",s:2,f:"So thoughtful!"},{t:"Good.",s:1,f:"Say 'I am happy you like it'."}]},
{npc:"Come on! Let us get some cake and play some games!",cn:"Time for cake and games!",opts:[{t:"Yay! I love cake! Let us go!",s:2,f:"Enthusiastic!"},{t:"OK.",s:1,f:"Show some excitement!"}]}
