<title>替身英语冒险</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--pu:#1a0a2e;--p2:#2d1b69;--gd:#ffd700;--pk:#ff6b9d;--tl:#00d4aa;--rd:#ff2d55;--bg:#0d0d1a;--cb:rgba(45,27,105,0.6);--mg:#9b59b6;--or:#ff8c00}
body{font-family:system-ui,sans-serif;background:var(--bg);color:#fff;min-height:100vh}
.container{max-width:480px;margin:0 auto;padding:16px;text-align:center}
.mt{font-size:28px;font-weight:900;background:linear-gradient(135deg,var(--gd),var(--pk),var(--tl));-webkit-background-clip:text;-webkit-text-fill-color:transparent;padding:20px 0 5px}
.mt-sub{font-size:10px;color:rgba(255,255,255,0.3);letter-spacing:4px;text-transform:uppercase;margin-top:-2px;margin-bottom:4px}

/* STAND ENERGY BAR */
.sb{background:rgba(255,255,255,0.1);border-radius:12px;padding:3px;margin:8px 0;border:1px solid var(--gd)}
.sb-in{height:20px;border-radius:10px;background:linear-gradient(90deg,var(--pk),var(--gd),var(--tl));width:0%;transition:width .5s}
.sl{display:flex;justify-content:space-between;font-size:11px;color:rgba(255,255,255,0.6);margin-bottom:4px}

/* STAND EVOLUTION DISPLAY */
.se-disp{background:linear-gradient(135deg,rgba(26,10,46,0.9),rgba(45,27,105,0.7));border:1px solid rgba(255,215,0,0.3);border-radius:14px;padding:8px 12px;margin:6px 0;display:flex;align-items:center;gap:10px;cursor:pointer}
.se-disp:active{border-color:var(--gd)}
.se-icon{font-size:24px;width:32px;text-align:center}
.se-info{flex:1;text-align:left}
.se-name{font-size:11px;font-weight:700;color:var(--gd)}
.se-lv{font-size:10px;color:rgba(255,255,255,0.5)}
.se-bar{margin-top:3px;height:4px;background:rgba(255,255,255,0.1);border-radius:2px;overflow:hidden}
.se-fill{height:100%;background:linear-gradient(90deg,var(--gd),var(--or));border-radius:2px;transition:width .5s}
.se-progress{font-size:9px;color:rgba(255,255,255,0.4);margin-left:4px;white-space:nowrap}

/* DAILY CHALLENGE CARD */
.dc-card{background:linear-gradient(135deg,rgba(0,212,170,0.08),rgba(255,107,157,0.08));border:1px solid rgba(255,215,0,0.25);border-radius:14px;padding:10px 12px;margin:8px 0;display:flex;align-items:center;gap:10px;cursor:pointer}
.dc-card:active{border-color:var(--gd)}
.dc-icon{font-size:22px;width:32px;text-align:center}
.dc-info{flex:1;text-align:left}
.dc-title{font-size:12px;font-weight:700;color:var(--tl)}
.dc-streak{font-size:10px;color:rgba(255,255,255,0.5)}
.dc-badge{font-size:10px;padding:3px 10px;border-radius:10px;background:var(--gd);color:#000;font-weight:700}

/* STARS DISPLAY */
.st{text-align:center;margin:6px 0 10px;font-size:20px;display:flex;align-items:center;justify-content:center;gap:4px}

/* MENU */
.mg{display:grid;gap:10px;margin-top:8px}
.mb{display:flex;align-items:center;gap:16px;background:var(--cb);border:1px solid rgba(255,215,0,0.2);border-radius:16px;padding:18px 20px;cursor:pointer}
.mb:active{transform:translateY(-2px);border-color:var(--gd)}
.mi{font-size:32px;width:50px;text-align:center}
.mf{flex:1;text-align:left}
.mf h3{font-size:16px;font-weight:700;color:#fff}
.mf p{font-size:12px;color:rgba(255,255,255,0.5)}
.md{display:none}.md.a{display:block}
.back{display:inline-flex;color:var(--gd);font-size:14px;cursor:pointer;margin-bottom:12px;padding:8px}

/* FIGHT CARD */
.wc{background:var(--cb);border:1px solid var(--gd);border-radius:20px;padding:30px 20px;margin-bottom:16px}
.wd{font-size:36px;font-weight:900;margin:8px 0}
.og{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.ob{padding:14px;border-radius:12px;border:1px solid rgba(255,255,255,0.15);background:rgba(255,255,255,0.05);color:#fff;font-size:15px;cursor:pointer;font-family:inherit;text-align:center}
.ob:active{background:rgba(255,215,0,0.15);border-color:var(--gd)}
.ob.cr{background:rgba(0,212,170,0.3);border-color:var(--tl)}
.ob.wr{background:rgba(255,45,85,0.3);border-color:var(--rd);animation:sk .3s}
@keyframes sk{0%,100%{transform:translateX(0)}25%{transform:translateX(-5px)}75%{transform:translateX(5px)}}
.ob:disabled{opacity:.7}
.pr{font-size:12px;color:rgba(255,255,255,0.4);margin:8px 0}
.rc{background:var(--cb);border:1px solid var(--gd);border-radius:20px;padding:24px;margin:16px 0}
.bc{display:flex;align-items:center;gap:14px;background:var(--cb);border:1px solid rgba(255,215,0,0.2);border-radius:16px;padding:14px 16px;cursor:pointer;margin-bottom:10px;text-align:left}
.bc:active{border-color:var(--gd)}.bc.l{opacity:.4;pointer-events:none}
.be{font-size:36px;width:48px;text-align:center}.bi{flex:1}
.bi h3{font-size:15px;font-weight:700}.bi p{font-size:11px;color:rgba(255,255,255,0.4)}
.bb{font-size:11px;padding:4px 10px;border-radius:10px}
.bb.g{background:var(--gd);color:#000}.bb.c{background:var(--tl);color:#000}.bb.l{background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.4)}

/* BOSS HP */
.bh{display:flex;align-items:center;gap:12px;margin-bottom:12px;text-align:left}.bnm{font-size:16px;font-weight:700;color:var(--gd)}
.bho{background:rgba(255,45,85,0.2);border-radius:8px;height:14px;padding:2px;border:1px solid var(--rd)}
.bhi{height:100%;border-radius:6px;background:linear-gradient(90deg,var(--rd),var(--gd));transition:width .4s;min-width:4%}
.bht{font-size:11px;color:rgba(255,255,255,0.5)}
.pl{font-size:20px;display:flex;gap:4px}
.ht-l{filter:grayscale(1);opacity:.3}

/* READING */
.rb{border:1px solid var(--tl);border-radius:16px;padding:20px;font-size:15px;line-height:1.8;text-align:left;background:var(--cb)}
.trans-btn{display:inline-block;margin-top:10px;padding:4px 12px;border-radius:8px;border:1px solid var(--gd);color:var(--gd);font-size:12px;cursor:pointer}
.trans-btn:active{background:rgba(255,215,0,0.1)}
.translation{display:none;margin-top:8px;padding:8px 12px;border-radius:8px;background:rgba(0,212,170,0.1);font-size:13px;color:var(--tl)}
.qi{padding:12px;margin-bottom:8px;text-align:left}
.question-text{font-size:14px;font-weight:600;margin-bottom:8px}
.qo{display:block;width:100%;padding:8px 12px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:rgba(255,255,255,0.03);color:#fff;font-size:13px;cursor:pointer;text-align:left;font-family:inherit;margin-bottom:4px}
.qo.cr{border-color:var(--tl);background:rgba(0,212,170,0.2)}
.qo.wr{border-color:var(--rd);background:rgba(255,45,85,0.2)}

/* DIALOGUE */
.cb{border-radius:16px;padding:16px;margin-bottom:12px;background:var(--cb);text-align:left}
.cbp{display:flex;gap:10px;margin-bottom:12px}.cbb{background:rgba(255,255,255,0.08);border-radius:12px 12px 12px 4px;padding:10px 14px;max-width:85%}
.cbn{font-size:12px;color:var(--pk)}
.cho{display:flex;align-items:center;gap:10px;padding:12px 14px;border-radius:12px;border:1px solid rgba(255,255,255,0.12);background:rgba(0,212,170,0.08);color:#fff;font-size:14px;cursor:pointer;text-align:left;font-family:inherit;margin-bottom:8px}
.cho:active{border-color:var(--tl)}.cho.s{border-color:var(--gd);pointer-events:none;background:rgba(255,215,0,0.15)}
.cf{font-size:13px;color:var(--gd);margin-top:4px;padding:6px;text-align:center}

/* OVERLAYS */
.or{position:fixed;inset:0;z-index:100;display:flex;align-items:center;justify-content:center;pointer-events:none;animation:of .8s forwards}
@keyframes of{0%{opacity:1;transform:scale(.8)}100%{opacity:0;transform:scale(1.5)}}
.sro{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.85);display:flex;flex-direction:column;align-items:center;justify-content:center;animation:ri .5s}
@keyframes ri{from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1}}

/* EVOLUTION OVERLAY */
.evo-overlay{position:fixed;inset:0;z-index:300;background:radial-gradient(ellipse at center,rgba(255,215,0,0.15),rgba(26,10,46,0.95));display:flex;flex-direction:column;align-items:center;justify-content:center;animation:evoIn .8s}
@keyframes evoIn{0%{opacity:0;transform:scale(0.3)}50%{opacity:1;transform:scale(1.1)}100%{transform:scale(1)}}
.evo-title{font-size:14px;color:rgba(255,255,255,0.5);letter-spacing:6px;text-transform:uppercase;margin-bottom:10px}
.evo-icon{font-size:64px;margin-bottom:10px;animation:evoGlow 1s ease-in-out infinite alternate}
@keyframes evoGlow{from{filter:drop-shadow(0 0 5px var(--gd))}to{filter:drop-shadow(0 0 20px var(--gd))}}
.evo-name{font-size:32px;font-weight:900;background:linear-gradient(135deg,var(--gd),var(--pk),var(--tl));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:4px}
.evo-jp{font-size:18px;color:rgba(255,255,255,0.4);font-style:italic;margin-bottom:16px}
.evo-desc{font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:20px}
.evo-btn{border:none;padding:10px 32px;border-radius:20px;border:2px solid var(--gd);background:transparent;color:var(--gd);font-size:14px;cursor:pointer;animation:evoPulse 1.5s infinite}
@keyframes evoPulse{0%,100%{box-shadow:0 0 5px var(--gd)}50%{box-shadow:0 0 20px var(--gd)}}

/* MENACING EFFECT */
.menacing{position:fixed;z-index:150;pointer-events:none;font-size:14px;letter-spacing:8px;color:rgba(255,215,0,0.25);animation:menaFade 2s forwards}
@keyframes menaFade{0%{opacity:1;transform:scale(0.5)}100%{opacity:0;transform:scale(2)}}

/* DAILY QUIZ */
.dq-blueprint{background:linear-gradient(135deg,rgba(0,212,170,0.05),rgba(155,89,182,0.05));border:1px solid rgba(0,212,170,0.2);border-radius:16px;padding:16px;margin-bottom:12px}
.dq-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.dq-day{font-size:12px;color:var(--tl)}
.dq-progress{font-size:11px;color:rgba(255,255,255,0.4)}
.dq-streak-bar{display:flex;gap:4px;margin-bottom:12px;justify-content:center}
.dq-streak-dot{width:20px;height:20px;border-radius:50%;background:rgba(255,255,255,0.1);display:inline-flex;align-items:center;justify-content:center;font-size:8px}
.dq-streak-dot.active{background:var(--tl);color:#000}
.dq-streak-dot.fire{background:var(--or);color:#000;animation:dqFire .5s ease-in-out infinite alternate}
@keyframes dqFire{from{transform:scale(1)}to{transform:scale(1.2)}}

/* EVOLUTION PAGE */
.evo-page{text-align:center}
.evo-current{background:linear-gradient(135deg,rgba(45,27,105,0.6),rgba(26,10,46,0.8));border:2px solid var(--gd);border-radius:20px;padding:20px;margin-bottom:16px}
.evo-big-icon{font-size:72px;margin-bottom:8px}
.evo-big-name{font-size:28px;font-weight:900;color:var(--gd);margin-bottom:4px}
.evo-big-jp{font-size:16px;color:rgba(255,255,255,0.3);margin-bottom:8px}
.evo-big-lv{font-size:14px;color:var(--tl)}
.evo-list{display:grid;gap:8px}
.evo-item{display:flex;align-items:center;gap:12px;background:var(--cb);border-radius:12px;padding:10px 14px;border:1px solid rgba(255,255,255,0.08)}
.evo-item.locked{opacity:0.4;filter:grayscale(0.5)}
.evo-item.current{border-color:var(--gd)}
.evo-item-icon{font-size:24px;width:30px;text-align:center}
.evo-item-info{flex:1;text-align:left}
.evo-item-name{font-size:13px;font-weight:700;color:#fff}
.evo-item-jp{font-size:10px;color:rgba(255,255,255,0.3)}
.evo-item-stars{font-size:10px;color:var(--gd)}

/* UTILITY */
.bo{border:none;margin-top:16px;padding:10px 32px;border-radius:20px;border:2px solid var(--gd);background:transparent;color:var(--gd);font-size:14px;cursor:pointer}
.sk{border:none;margin:6px;padding:10px 28px;border-radius:20px;border:2px solid var(--gd);background:transparent;color:var(--gd);font-size:13px;cursor:pointer}
.sk:active{background:var(--gd);color:#000}
</style></head><body>
